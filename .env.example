# Database (Neon Serverless PostgreSQL)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-1.aws.neon.tech/modelforge?sslmode=require"
# Direct URL for migrations (bypasses connection pooler)
DIRECT_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-1.aws.neon.tech/modelforge?sslmode=require"

# App URL (used for Stripe redirect URLs etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs
STRIPE_STARTER_MONTHLY_PRICE_ID="price_..."
STRIPE_STARTER_YEARLY_PRICE_ID="price_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."

# LLM Provider
GEMINI_API_KEY="your-gemini-api-key"
FIRECRAWL_API_KEY="your-firecrawl-api-key"

# Together.ai (for GTE-ModernBERT embeddings)
TOGETHER_API_KEY="your-together-api-key"

# Neural 3D Generation
# Provider routing: "fal" (hosted, recommended) or "self-hosted"
NEURAL_PROVIDER=fal
FAL_KEY="your-fal-ai-api-key"

# Cloudflare R2 asset library storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional metadata hook; asset reads still go through signed URLs in this branch.
R2_PUBLIC_BASE_URL=""

# Self-hosted endpoints (only if NEURAL_PROVIDER=self-hosted)
HUNYUAN_API_URL="http://localhost:8080"

# RunPod Serverless (for models without hosted APIs)
RUNPOD_API_KEY=""
RUNPOD_ENDPOINT_HUNYUAN_PAINT=""
RUNPOD_ENDPOINT_HUNYUAN_PART=""
RUNPOD_ENDPOINT_UNIRIG=""
RUNPOD_ENDPOINT_MOMASK=""
RUNPOD_ENDPOINT_MESHANYTHING=""

# YVO3D API (premium texturing)
YVO3D_API_KEY=""

# Brave Search API
BRAVE_API_KEY=""

# Blender MCP (local add-on server)
BLENDER_MCP_HOST="127.0.0.1"
BLENDER_MCP_PORT="9876"

# Desktop shell (Electron)
MODELFORGE_DESKTOP_START_URL="http://localhost:3000/dashboard"

# OAuth Providers (configure in Supabase dashboard)
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set in Supabase Auth > Providers > Google

# LangSmith Observability (optional — enables agent tracing)
# Get your API key from https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY="lsv2_pt_your_key_here"
LANGSMITH_PROJECT="modelforge"
